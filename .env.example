# Proxmox API connection
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_VERIFY_SSL=false
PROXMOX_TOKEN_ID=proxkey@pve!proxkey
PROXMOX_TOKEN_SECRET=your-token-secret-here
PROXMOX_NODE=pve

# SSH to Proxmox host (needed when running ProxKey remotely, not on the PVE host)
# Leave PROXMOX_SSH_PASSWORD empty if running directly on the Proxmox host
PROXMOX_SSH_USER=root
PROXMOX_SSH_PASSWORD=
PROXMOX_SSH_PORT=22

# App settings
SECRET_KEY=change-me-to-a-random-string
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
